---
// Featured Categories — two image-backed category cards with dark gradient overlay
const categories = [
  {
    href: '/productos#buzo',
    image: '/custom-hoddie.png',
    alt: 'Sudadera personalizada con mascota',
    title: 'Sudaderas Personalizadas',
    desc: 'Luce a tu mascota con orgullo en una sudadera diseñada a medida.',
    cta: 'Ver sudaderas →',
  },
  {
    href: '/productos#kit',
    image: '/pet-paint-kit.png',
    alt: 'Kit de pintura por números de mascota',
    title: 'Kits de Pintura por Números',
    desc: 'Crea una obra maestra de tu mascota, un número a la vez.',
    cta: 'Ver kits →',
  },
];
---

<section id="categories" class="bg-brand-white py-14 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="reveal flex items-end justify-between gap-5 flex-wrap mb-9">
      <div>
        <div class="text-xs font-extrabold tracking-widest uppercase text-brand-orange mb-2.5">Categorías</div>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-dark">Dos formas de celebrar a tu mascota</h2>
      </div>
      <a href="/productos" class="text-sm font-bold text-brand-orange hover:text-brand-brown transition-colors">Ver productos →</a>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {categories.map((cat, i) => (
        <a
          href={cat.href}
          class:list={['reveal', i === 1 && 'reveal-delay-1', 'group relative block rounded-3xl overflow-hidden bg-brand-tan aspect-[16/11] text-white shadow-sm hover:shadow-xl hover:shadow-brand-dark/25 transition-shadow']}
        >
          <img
            src={cat.image}
            alt={cat.alt}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/80 via-brand-dark/10 to-transparent" aria-hidden="true"></div>
          <div class="absolute left-6 right-6 bottom-6">
            <h3 class="text-xl md:text-2xl font-extrabold tracking-tight mb-1.5">{cat.title}</h3>
            <p class="text-sm text-white/85 leading-relaxed mb-3">{cat.desc}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-bold bg-white/20 backdrop-blur border border-white/35 rounded-full px-4 py-2">
              {cat.cta}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
