---
// Featured Categories — two product category cards
const categories = [
  {
    title: 'Custom Pet Hoodies',
    description: 'Wear your pet proudly with our custom-designed hoodies featuring your furry friend.',
    placeholder: 'Hoodie image',
    href: '#',
  },
  {
    title: 'Pet Paint by Number Kits',
    description: 'Create a masterpiece of your pet with our easy-to-follow paint-by-number kits.',
    placeholder: 'Paint kit image',
    href: '#',
  },
];
---

<section id="categories" class="bg-brand-white py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-serif font-bold text-center mb-12 text-brand-brown">
      Our Featured Categories
    </h2>

    <div class="grid md:grid-cols-2 gap-8">
      {categories.map((cat) => (
        <a href={cat.href} class="group block bg-brand-cream rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <!-- Image placeholder -->
          <div class="aspect-4/3 bg-brand-tan flex items-center justify-center">
            <p class="text-brand-brown/40 text-sm">{cat.placeholder}</p>
          </div>
          <!-- Card text -->
          <div class="p-6">
            <h3 class="text-xl font-serif font-bold text-brand-brown group-hover:text-brand-orange transition-colors">
              {cat.title}
            </h3>
            <p class="mt-2 text-brand-brown/70">{cat.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
