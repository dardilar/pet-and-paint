---
// Footer — branding, link columns, copyright
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-brand-tan border-t border-brand-tan/20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex flex-wrap items-center justify-between gap-5">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5 font-extrabold text-lg text-white">
      <span class="w-8 h-8 rounded-lg bg-brand-orange text-white grid place-items-center text-sm" aria-hidden="true">🐾</span>
      Pet & Paint
    </a>

    <!-- Links -->
    <nav class="flex items-center gap-7 flex-wrap">
      <a href="/" class="text-sm text-brand-orange hover:text-white transition-colors">Inicio</a>
      <a href="/productos" class="text-sm text-brand-orange hover:text-white transition-colors">Productos</a>
      <a href="/#mission" class="text-sm text-brand-orange hover:text-white transition-colors">Nuestra Misión</a>
      <a href="/pedido" class="text-sm text-brand-orange hover:text-white transition-colors">Contacto</a>
    </nav>

    <!-- Copyright -->
    <span class="text-xs text-brand-tan/60">&copy; {currentYear} Pet & Paint</span>
  </div>
</footer>
