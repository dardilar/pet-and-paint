---
// Footer — branding, link columns, copyright
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="space-y-4">
        <span class="text-2xl font-serif font-bold">Pet & Paint</span>
        <p class="text-white/70 text-sm" data-i18n="footer.tagline">
          Celebrando el vínculo entre las mascotas y sus personas a través del arte vestible personalizado y kits creativos.
        </p>
      </div>

      <!-- Shop column -->
      <div>
        <h4 class="font-semibold mb-4" data-i18n="footer.shopCol">Tienda</h4>
        <ul class="space-y-2 text-white/70 text-sm">
          <li><a href="#" class="hover:text-white transition-colors" data-i18n="footer.shopHoodies">Sudaderas Personalizadas</a></li>
          <li><a href="#" class="hover:text-white transition-colors" data-i18n="footer.shopKits">Kits de Pintura por Números</a></li>
          <li><a href="/order" class="hover:text-white transition-colors" data-i18n="footer.shopOrder">Pedido Personalizado</a></li>
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h4 class="font-semibold mb-4" data-i18n="footer.companyCol">Empresa</h4>
        <ul class="space-y-2 text-white/70 text-sm">
          <li><a href="#" class="hover:text-white transition-colors" data-i18n="footer.companyAbout">Sobre Nosotros</a></li>
          <li><a href="#" class="hover:text-white transition-colors" data-i18n="footer.companyMission">Nuestra Misión</a></li>
          <li><a href="#" class="hover:text-white transition-colors" data-i18n="footer.companyContact">Contacto</a></li>
        </ul>
      </div>

      <!-- Connect column -->
      <div>
        <h4 class="font-semibold mb-4" data-i18n="footer.connectCol">Conecta</h4>
        <ul class="space-y-2 text-white/70 text-sm">
          <li><a href="#" class="hover:text-white transition-colors">Instagram</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Facebook</a></li>
          <li><a href="#" class="hover:text-white transition-colors">TikTok</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/20 mt-8 pt-8 text-center text-white/50 text-sm">
      &copy; {currentYear} Pet & Paint. <span data-i18n="footer.copyright">Todos los derechos reservados.</span>
    </div>
  </div>
</footer>
