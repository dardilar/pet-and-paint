---
// Hero section — headline, subtext, CTA buttons, and image placeholder
---

<section class="bg-brand-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-6">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold leading-tight text-brand-brown">
          Wear Your Love,<br />
          <span class="text-brand-orange">Paint Your Bond</span>
        </h1>
        <p class="text-lg text-brand-brown/80 max-w-md">
          Custom pet hoodies and DIY paint-by-number kits that celebrate
          the bond between you and your furry best friend.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#categories"
            class="bg-brand-brown text-white px-8 py-3 rounded-full font-semibold hover:bg-brand-orange transition-colors"
          >
            Shop Hoodies
          </a>
          <a
            href="#categories"
            class="border-2 border-brand-brown text-brand-brown px-8 py-3 rounded-full font-semibold hover:bg-brand-brown hover:text-white transition-colors"
          >
            Shop Paint Kits
          </a>
        </div>
      </div>

      <!-- Right: Hero Image Placeholder -->
      <div class="flex justify-center">
        <div class="w-full max-w-md aspect-4/5 bg-brand-tan rounded-2xl flex items-center justify-center overflow-hidden">
          <div class="text-center text-brand-brown/50 p-8">
            <svg class="w-24 h-24 mx-auto mb-4 opacity-40" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-4.5-2c-.83 0-1.5.67-1.5 1.5S6.67 11 7.5 11 9 10.33 9 9.5 8.33 8 7.5 8zm9 0c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5S17.33 8 16.5 8zm-4.5-4c-.83 0-1.5.67-1.5 1.5S11.17 7 12 7s1.5-.67 1.5-1.5S12.83 4 12 4zm0 12c-2.21 0-4 1.12-4 2.5S9.79 21 12 21s4-1.12 4-2.5S14.21 16 12 16z"/>
            </svg>
            <p class="text-sm">Hero image: person with dog</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
