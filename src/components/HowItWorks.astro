---
// How It Works — three-step process
const steps = [
  {
    number: '1',
    title: 'Upload Your Photo',
    description: 'Upload your favourite pet photo — any breed, any pose, any personality.',
    icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    number: '2',
    title: 'Choose Your Product',
    description: 'Pick from our custom pet hoodies, paint-by-number kits, or both.',
    icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z',
  },
  {
    number: '3',
    title: 'Receive Your Creation',
    description: 'We craft it with care and ship it to your door. Ready to wear or paint.',
    icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4',
  },
];
---

<section id="how-it-works" class="bg-brand-cream py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="reveal text-3xl md:text-4xl font-serif font-bold text-center mb-4 text-brand-brown">
      Create Your Masterpiece in 3 Steps
    </h2>
    <p class="reveal reveal-delay-1 text-center text-brand-brown/70 mb-12 max-w-2xl mx-auto">
      Upload your pet photo, choose a one-of-a-kind product, and let us do the rest.
      Fun, easy, and perfect for any pet lover.
    </p>

    <div class="grid md:grid-cols-3 gap-8 mb-12">
      {steps.map((step, i) => (
        <div class:list={['reveal', `reveal-delay-${i}`, 'text-center', 'space-y-4']}>
          <div class="w-20 h-20 mx-auto bg-brand-tan rounded-full flex items-center justify-center">
            <svg class="w-10 h-10 text-brand-brown" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-serif font-bold text-brand-brown">
            <span class="text-brand-orange">Step {step.number}:</span> {step.title}
          </h3>
          <p class="text-brand-brown/70 max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="reveal text-center">
      <a
        href="#categories"
        class="inline-block bg-brand-brown text-white px-8 py-3 rounded-full font-semibold hover:bg-brand-orange transition-colors"
      >
        Get Started
      </a>
    </div>
  </div>
</section>
