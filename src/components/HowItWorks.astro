---
// How It Works — three numbered step cards
const steps = [
  {
    number: '1',
    emoji: '🧥',
    title: 'Elige tu producto',
    description: 'Elige entre nuestras sudaderas personalizadas o kits de pintura por números.',
  },
  {
    number: '2',
    emoji: '📷',
    title: 'Sube tu foto',
    description: 'Sube la foto de tu mascota — o la huella si elegiste esa opción.',
  },
  {
    number: '3',
    emoji: '📦',
    title: 'Recibe tu creación',
    description: 'Lo elaboramos con cuidado y lo enviamos a tu puerta, listo para usar o pintar.',
  },
];
---

<section id="how-it-works" class="bg-brand-white py-14 md:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <div class="reveal text-xs font-extrabold tracking-widest uppercase text-brand-orange mb-2.5">Cómo funciona</div>
    <h2 class="reveal text-3xl md:text-4xl font-extrabold tracking-tight text-brand-dark mb-3">
      Tu obra maestra en 3 pasos
    </h2>
    <p class="reveal reveal-delay-1 text-brand-brown mb-12 max-w-lg mx-auto leading-relaxed">
      Elige tu producto, sube la foto de tu mascota y déjanos hacer el resto.
    </p>

    <div class="grid sm:grid-cols-3 gap-7 text-left">
      {steps.map((step, i) => (
        <div class:list={['reveal', `reveal-delay-${i}`, 'bg-brand-cream rounded-3xl p-7']}>
          <div class="flex items-center gap-3.5 mb-4">
            <span class="w-11 h-11 rounded-full bg-brand-dark text-white grid place-items-center text-lg font-extrabold shrink-0">{step.number}</span>
            <span class="text-2xl" aria-hidden="true">{step.emoji}</span>
          </div>
          <h3 class="text-lg font-extrabold text-brand-dark mb-2">{step.title}</h3>
          <p class="text-sm text-brand-brown leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="reveal">
      <a
        href="/pedido"
        class="inline-block mt-11 bg-brand-brown text-white px-8 py-3.5 rounded-full font-bold hover:bg-brand-orange transition-colors"
      >
        Comenzar mi pedido
      </a>
    </div>
  </div>
</section>
