---
// Navbar — sticky top navigation with blur background and mobile hamburger menu
interface Props {
  active?: 'productos' | 'pedido';
}
const { active } = Astro.props;

const links = [
  { href: '/#mission', label: 'Nuestra Misión', key: 'mission' },
  { href: '/#how-it-works', label: 'Cómo Funciona', key: 'how' },
  { href: '/productos', label: 'Productos', key: 'productos' },
  { href: '/pedido', label: 'Pedido Personalizado', key: 'pedido' },
];
---

<header class="w-full sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-brand-tan">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center gap-7 h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 font-extrabold text-lg tracking-tight text-brand-dark">
      <span class="w-[34px] h-[34px] rounded-xl text-white grid place-items-center text-base" aria-hidden="true">🐾</span>
      Pet & Paint
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden md:flex items-center gap-6 ml-auto">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors',
            active === link.key
              ? 'font-extrabold text-brand-dark border-b-2 border-brand-orange pb-0.5'
              : 'font-semibold text-brand-brown hover:text-brand-orange',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <a
      href="/pedido"
      class="hidden md:inline-block bg-brand-brown text-white text-sm font-bold px-5 py-2.5 rounded-full hover:bg-brand-dark transition-colors"
    >
      Pedir Ahora
    </a>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden ml-auto p-2 text-brand-brown"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden px-4 pb-4 space-y-1 border-t border-brand-tan/60 bg-white/95">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'block py-2.5 text-sm',
          active === link.key ? 'font-extrabold text-brand-dark' : 'font-semibold text-brand-brown hover:text-brand-orange',
        ]}
      >
        {link.label}
      </a>
    ))}
    <a href="/pedido" class="inline-block mt-2 bg-brand-brown text-white text-sm font-bold px-5 py-2.5 rounded-full hover:bg-brand-dark transition-colors">
      Pedir Ahora
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
