---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturedCategories from '../components/FeaturedCategories.astro';
import MissionSection from '../components/MissionSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Pet & Paint — Viste tu amor, pinta tu vínculo">
  <!-- Announcement bar -->
  <div class="bg-brand-dark text-brand-tan text-[13px] font-medium text-center px-4 py-2 tracking-wide">
    Cada compra ayuda a alimentar y refugiar mascotas rescatadas ·
    <a href="#mission" class="text-brand-orange font-bold hover:text-brand-cream transition-colors">Conoce nuestra misión</a>
  </div>
  <Navbar />
  <main>
    <HeroSection />
    <FeaturedCategories />
    <MissionSection />
    <HowItWorks />
  </main>
  <Footer />
</Layout>
