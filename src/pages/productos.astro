---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { PRODUCTS, STYLES, STYLE_KEYS, SIZES, formatPrice, getMinPrice } from '../data/products';

const buyingSteps = [
  { title: 'Envías tu pedido', desc: 'Eliges producto y estilo, subes la foto y nos dejas tus datos.' },
  { title: 'Revisamos tu foto', desc: 'Confirmamos que la calidad sea perfecta para ilustrar a tu mascota.' },
  { title: 'Recibes tu link de pago', desc: 'Te llega a tu correo. Pagas seguro y empezamos a crear tu pieza.' },
];
---

<Layout title="Productos — Pet & Paint">
  <Navbar active="productos" />
  <main>
    <!-- Intro -->
    <section class="pt-10 md:pt-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto text-center">
        <div class="text-xs font-extrabold tracking-widest uppercase text-brand-orange mb-3">Nuestros productos</div>
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-brand-dark mb-3.5">Dos productos, hechos solo para ti</h1>
        <p class="text-brand-brown max-w-lg mx-auto leading-relaxed">
          Cada pieza se crea desde cero con la foto de tu mascota. Elige tu favorito y personalízalo en minutos.
        </p>
      </div>
    </section>

    <!-- BUZO -->
    <section id="buzo" class="py-12 md:py-20 px-4 sm:px-6 scroll-mt-16">
      <div class="max-w-5xl mx-auto flex flex-wrap gap-9 md:gap-16 items-start">
        <!-- Gallery -->
        <div class="reveal flex-[1_1_400px] min-w-[300px]">
          <div class="relative">
            <div class="w-full aspect-[4/3.4] rounded-3xl overflow-hidden shadow-xl shadow-brand-dark/15">
              <img src="/custom-hoddie.png" alt="Sudadera personalizada con el retrato de tu mascota" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -top-3.5 -right-2 bg-brand-orange text-white text-[13px] font-extrabold rounded-full px-4.5 py-2 shadow-lg shadow-brand-orange/40 animate-[floaty_3.5s_ease-in-out_infinite]">
              Desde {formatPrice(getMinPrice('hoodie'))}
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-3.5">
            <div class="aspect-square rounded-2xl overflow-hidden">
              <img src="/wear-your-pet.png" alt="Cliente usando sudadera con su mascota" class="w-full h-full object-cover" />
            </div>
            <div class="aspect-square rounded-2xl overflow-hidden">
              <img src="/hero-green.png" alt="Detalle del retrato estampado en la sudadera" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
        <!-- Details -->
        <div class="reveal reveal-delay-1 flex-[1_1_380px] min-w-[300px]">
          <div class="inline-block bg-brand-tan rounded-full text-xs font-extrabold tracking-widest uppercase text-brand-brown px-3.5 py-1.5 mb-4">
            Sudadera personalizada
          </div>
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-dark mb-3.5">El Buzo</h2>
          <p class="text-brand-brown leading-relaxed mb-6">
            Tu mascota ilustrada a mano y estampada en una sudadera premium de algodón. Un retrato que llevas puesto todos los días.
          </p>

          <div class="text-sm font-extrabold text-brand-dark mb-3">Estilos disponibles</div>
          <div class="flex flex-col gap-2.5 mb-6">
            {STYLE_KEYS.map((key) => (
              <div class="flex items-center justify-between bg-white border-[1.5px] border-brand-tan rounded-2xl px-4.5 py-3">
                <span class="text-sm font-bold text-brand-dark">{STYLES[key].emoji} {STYLES[key].name}</span>
                <span class="text-sm font-extrabold text-brand-orange">{formatPrice(PRODUCTS.hoodie.styles[key])}</span>
              </div>
            ))}
          </div>

          <div class="flex items-center gap-2.5 flex-wrap mb-7">
            <span class="text-sm font-extrabold text-brand-dark">Tallas:</span>
            <span class="flex gap-2">
              {SIZES.map((size) => (
                <span class="min-w-10 h-10 px-2 rounded-full border-[1.5px] border-brand-tan bg-white grid place-items-center text-[13px] font-bold text-brand-brown">{size}</span>
              ))}
            </span>
          </div>

          <a
            href="/pedido"
            class="inline-block bg-brand-orange text-white font-bold px-8 py-3.5 rounded-full shadow-lg shadow-brand-orange/35 hover:bg-brand-brown transition-colors"
          >
            Personalizar mi buzo →
          </a>
        </div>
      </div>
    </section>

    <!-- KIT -->
    <section id="kit" class="bg-brand-white py-12 md:py-20 px-4 sm:px-6 scroll-mt-16">
      <div class="max-w-5xl mx-auto flex flex-wrap-reverse gap-9 md:gap-16 items-start">
        <!-- Details -->
        <div class="reveal flex-[1_1_380px] min-w-[300px]">
          <div class="inline-block bg-brand-cream rounded-full text-xs font-extrabold tracking-widest uppercase text-brand-brown px-3.5 py-1.5 mb-4">
            Pintura por números
          </div>
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-dark mb-3.5">El Kit de Pintura</h2>
          <p class="text-brand-brown leading-relaxed mb-6">
            Convertimos la foto de tu mascota en un lienzo numerado listo para pintar. Una experiencia relajante con un resultado que enmarcas.
          </p>

          <div class="text-sm font-extrabold text-brand-dark mb-3">Estilos disponibles</div>
          <div class="flex flex-col gap-2.5 mb-6">
            {STYLE_KEYS.map((key) => (
              <div class="flex items-center justify-between bg-brand-cream border-[1.5px] border-brand-tan rounded-2xl px-4.5 py-3">
                <span class="text-sm font-bold text-brand-dark">{STYLES[key].emoji} {STYLES[key].name}</span>
                <span class="text-sm font-extrabold text-brand-orange">{formatPrice(PRODUCTS.kit.styles[key])}</span>
              </div>
            ))}
          </div>

          <div class="text-sm font-extrabold text-brand-dark mb-3">Qué incluye</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-7">
            {['Lienzo numerado de tu foto', 'Set de pinturas acrílicas', 'Pinceles de 3 tamaños', 'Guía paso a paso'].map((item) => (
              <span class="flex items-center gap-2 text-sm font-semibold text-brand-brown">
                <span class="text-brand-orange" aria-hidden="true">✓</span>
                {item}
              </span>
            ))}
          </div>

          <a
            href="/pedido"
            class="inline-block bg-brand-orange text-white font-bold px-8 py-3.5 rounded-full shadow-lg shadow-brand-orange/35 hover:bg-brand-brown transition-colors"
          >
            Personalizar mi kit →
          </a>
        </div>
        <!-- Gallery -->
        <div class="reveal reveal-delay-1 flex-[1_1_400px] min-w-[300px]">
          <div class="relative">
            <div class="w-full aspect-[4/3.4] rounded-3xl overflow-hidden shadow-xl shadow-brand-dark/15">
              <img src="/pet-paint-kit.png" alt="Kit de pintura por números de tu mascota" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -top-3.5 -left-2 bg-brand-brown text-white text-[13px] font-extrabold rounded-full px-4.5 py-2 shadow-lg shadow-brand-brown/35 animate-[floaty_3.5s_ease-in-out_infinite]">
              Desde {formatPrice(getMinPrice('kit'))}
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-3.5">
            <div class="aspect-square rounded-2xl overflow-hidden">
              <img src="/paint-your-pet.png" alt="Proceso de pintura del lienzo numerado" class="w-full h-full object-cover" />
            </div>
            <div class="aspect-square rounded-2xl overflow-hidden">
              <img src="/pet-paint-kit.png" alt="Resultado final del kit de pintura" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Payment flow -->
    <section class="bg-brand-dark text-brand-cream py-12 md:py-20 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-[34px] font-extrabold tracking-tight mb-2.5">¿Cómo funciona la compra?</h2>
        <p class="text-brand-tan max-w-md mx-auto leading-relaxed mb-10">
          Sin carrito ni pagos a ciegas: revisamos tu foto antes de cobrarte.
        </p>
        <div class="grid sm:grid-cols-3 gap-5 text-left">
          {buyingSteps.map((step, i) => (
            <div class="bg-brand-cream/5 border border-brand-cream/15 rounded-2xl p-5.5">
              <div class="w-9 h-9 rounded-full bg-brand-orange text-white grid place-items-center text-sm font-extrabold mb-3.5">{i + 1}</div>
              <div class="font-extrabold mb-1.5">{step.title}</div>
              <div class="text-sm text-brand-tan leading-relaxed">{step.desc}</div>
            </div>
          ))}
        </div>
        <a
          href="/pedido"
          class="inline-block mt-10 bg-brand-orange text-white font-bold px-8 py-3.5 rounded-full hover:bg-brand-cream hover:text-brand-dark transition-colors"
        >
          Comenzar mi pedido
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
